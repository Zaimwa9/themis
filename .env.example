# --- required ---------------------------------------------------------------
# GitHub App credentials (create the App per README step 1)
THEMIS_GH_APP_CLIENT_ID=
# Private key: paste the PEM, or base64 of it, single line, no wrapping
# (macOS: base64 -i key.pem | tr -d '\n'   Linux: base64 -w0 key.pem)
THEMIS_GH_APP_PRIVATE_KEY=
# Webhook secret shared with the GitHub App settings
# (not needed in headless mode: THEMIS_WEBHOOK_ENABLED=false)
THEMIS_GH_WEBHOOK_SECRET=

# --- optional ---------------------------------------------------------------
# Public base URL of this instance. When set, Themis points the GitHub App's
# webhook at ${THEMIS_PUBLIC_URL}/webhook on startup.
#THEMIS_PUBLIC_URL=

# ngrok agent API for tunnel URL auto-discovery (compose tunnel profile).
#THEMIS_TUNNEL_API=http://ngrok:4040
# ngrok authtoken used by the tunnel sidecar itself
#NGROK_AUTHTOKEN=

# Restrict to specific repos even where the App is installed (comma-separated).
#THEMIS_REPOS=owner/repo,owner/other

# Codex sandbox: workspace-write (default) needs Landlock/namespaces in the
# container runtime; on platforms without it the container is the boundary:
#THEMIS_CODEX_SANDBOX=danger-full-access

# Review engine used when a repo does not set one in .themis/config.yaml.
#THEMIS_ENGINE=codex

# Claude subscription auth for the claude engine: run `claude setup-token`
# once on your machine (needs a Claude Pro/Max subscription) and paste the token.
#CLAUDE_CODE_OAUTH_TOKEN=

# Z.ai GLM Coding Plan API key for the glm engine (agent container only,
# no CLI login needed).
#GLM_API_KEY=

# Alibaba Cloud Model Studio (Qwen Coding Plan international) API key for
# the qwen engine (agent container only, no CLI login needed).
#QWEN_API_KEY=

# Headless mode: disable the webhook route, enable the trigger API.
#THEMIS_WEBHOOK_ENABLED=false
#THEMIS_API_TOKEN=

# Scratch root for PR clone workspaces (default matches the Dockerfile).
#THEMIS_WORKSPACE_ROOT=/tmp/themis

# Where codex keeps auth.json (mounted volume; see README)
#CODEX_HOME=/data/codex
#PORT=8000
